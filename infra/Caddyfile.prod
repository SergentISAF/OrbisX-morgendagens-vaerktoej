{
    admin off
    auto_https off
}

:80 {
    encode gzip zstd

    @api path /api/* /docs* /openapi.json /health /redoc*
    handle @api {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy dashboard:4321
    }

    header -Server
    header X-Content-Type-Options "nosniff"
    header Referrer-Policy "strict-origin-when-cross-origin"
}
