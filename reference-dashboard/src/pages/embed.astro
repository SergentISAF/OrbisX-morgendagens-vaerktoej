---
import "../styles/global.css";
import EmbedAve from "../components/EmbedAve";
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrbisX Embed</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      html, body {
        background: transparent;
        margin: 0;
        font-family: Inter, system-ui, sans-serif;
      }
    </style>
  </head>
  <body>
    <EmbedAve client:load />
  </body>
</html>
