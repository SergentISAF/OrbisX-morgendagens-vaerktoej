---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle";
import ApiStatus from "../components/ApiStatus";
import BrandOverview from "../components/BrandOverview";
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrbisX — Reference Dashboard</title>
    <script is:inline>
      const t = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (t === "dark" || (!t && prefersDark)) document.documentElement.classList.add("dark");
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="border-b border-[rgb(var(--border))]">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <div class="flex items-center gap-3">
          <span class="font-serif text-2xl font-semibold tracking-tight">OrbisX</span>
          <span class="text-xs text-[rgb(var(--muted))]">arbejdsnavn</span>
        </div>
        <ThemeToggle client:load />
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-16">
      <div class="max-w-2xl">
        <p class="mb-4 text-sm uppercase tracking-widest text-[rgb(var(--muted))]">
          Brand-monitor (fase 6 lite)
        </p>
        <h1 class="font-serif text-5xl font-semibold leading-tight tracking-tight">
          Hvor meget bliver dit brand omtalt?
        </h1>
        <p class="mt-6 text-lg text-[rgb(var(--muted))]">
          Indtast et brand. Vi viser hvor mange medier der har skrevet om det, hvilke der
          dækker mest, og hvor længe historierne ligger på forsiderne.
        </p>

        <div class="mt-8 flex items-center gap-3">
          <ApiStatus client:load />
          <a
            href="http://localhost:8000/docs"
            class="text-sm text-[rgb(var(--muted))] underline-offset-4 hover:underline"
          >
            API-docs →
          </a>
        </div>
      </div>

      <BrandOverview client:load />

      <section class="mt-24 grid grid-cols-1 gap-6 sm:grid-cols-2">
        <article class="rounded-xl border border-dashed border-[rgb(var(--border))] p-6">
          <h2 class="font-serif text-xl font-semibold text-[rgb(var(--muted))]">
            Sponsorat-tracker
          </h2>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            Co-omtaler af sponsor og sponseret. Værdi over tid. Kommer i fase 7.
          </p>
        </article>
        <article class="rounded-xl border border-dashed border-[rgb(var(--border))] p-6">
          <h2 class="font-serif text-xl font-semibold text-[rgb(var(--muted))]">
            Konkurrent-sammenligning
          </h2>
          <p class="mt-2 text-sm text-[rgb(var(--muted))]">
            Op til 5 brands side-by-side. Share-of-Voice. Kommer i fase 8.
          </p>
        </article>
      </section>
    </main>

    <footer class="mt-24 border-t border-[rgb(var(--border))]">
      <div class="mx-auto max-w-6xl px-6 py-6 text-xs text-[rgb(var(--muted))]">
        Bygget på OrbisX v2 API. Endeligt brand-navn vælges senere.
      </div>
    </footer>
  </body>
</html>
