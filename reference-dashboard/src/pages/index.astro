---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle";
import ApiStatus from "../components/ApiStatus";
import BrandOverview from "../components/BrandOverview";
import BrandCompare from "../components/BrandCompare";
import ReportForm from "../components/ReportForm";
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OrbisX — Reference Dashboard</title>
    <script is:inline>
      const t = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (t === "dark" || (!t && prefersDark)) document.documentElement.classList.add("dark");
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="border-b border-[rgb(var(--border))]">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <div class="flex items-center gap-3">
          <span class="font-serif text-2xl font-semibold tracking-tight">OrbisX</span>
          <span class="text-xs text-[rgb(var(--muted))]">arbejdsnavn</span>
        </div>
        <ThemeToggle client:load />
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-16">
      <div class="max-w-2xl">
        <p class="mb-4 text-sm uppercase tracking-widest text-[rgb(var(--muted))]">
          Brand-monitor (fase 6 lite)
        </p>
        <h1 class="font-serif text-5xl font-semibold leading-tight tracking-tight">
          Hvor meget bliver dit brand omtalt?
        </h1>
        <p class="mt-6 text-lg text-[rgb(var(--muted))]">
          Indtast et brand. Vi viser hvor mange medier der har skrevet om det, hvilke der
          dækker mest, og hvor længe historierne ligger på forsiderne.
        </p>

        <div class="mt-8 flex items-center gap-3">
          <ApiStatus client:load />
          <a
            href="http://localhost:8000/docs"
            class="text-sm text-[rgb(var(--muted))] underline-offset-4 hover:underline"
          >
            API-docs →
          </a>
        </div>
      </div>

      <BrandOverview client:load />

      <BrandCompare client:load />

      <section class="mt-24">
        <p class="mb-4 text-sm uppercase tracking-widest text-[rgb(var(--muted))]">
          Sponsorat-rapport
        </p>
        <h2 class="font-serif text-4xl font-semibold leading-tight tracking-tight">
          Lav rapport til en kunde
        </h2>
        <p class="mt-4 max-w-2xl text-base text-[rgb(var(--muted))]">
          Print-klar rapport om en sponseret entitets samlede mediedækning,
          klar til at give videre til hovedsponsoren. Indtast to søgeord —
          vi finder også hvor de optræder sammen.
        </p>
        <ReportForm client:load />
      </section>

      <section class="mt-24">
        <p class="mb-4 text-sm uppercase tracking-widest text-[rgb(var(--muted))]">
          Embed-widget
        </p>
        <h2 class="font-serif text-4xl font-semibold leading-tight tracking-tight">
          Plug-and-play på kundens hjemmeside
        </h2>
        <p class="mt-4 max-w-2xl text-base text-[rgb(var(--muted))]">
          Kunden dryppes et iframe på sin egen sponsor-side. Tallet opdaterer
          sig live mod OrbisX. Eksempel:
        </p>

        <div class="mt-6 rounded-xl border border-[rgb(var(--border))] overflow-hidden">
          <iframe
            src="/embed?sponsored=Aalborg+Håndbold&color=%23c8102e&label=Vores+mediedækning+i+2026"
            class="w-full h-[180px] border-0"
            title="Live AVE-widget for Aalborg Håndbold"
          ></iframe>
        </div>

        <details class="mt-4 text-sm">
          <summary class="cursor-pointer text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition">
            Vis HTML-snippet kunden kan kopiere
          </summary>
          <pre class="mt-3 overflow-x-auto rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--border))]/15 p-4 font-mono text-xs"><code>&lt;iframe
  src=&quot;https://dit-domæne.dk/embed?sponsored=Aalborg+H%C3%A5ndbold&amp;color=%23c8102e&amp;label=Vores+mediedækning&quot;
  width=&quot;100%&quot;
  height=&quot;180&quot;
  frameborder=&quot;0&quot;
  title=&quot;Mediedækning&quot;
&gt;&lt;/iframe&gt;</code></pre>
        </details>
      </section>
    </main>

    <footer class="mt-24 border-t border-[rgb(var(--border))]">
      <div class="mx-auto max-w-6xl px-6 py-6 text-xs text-[rgb(var(--muted))]">
        Bygget på OrbisX v2 API. Endeligt brand-navn vælges senere.
      </div>
    </footer>
  </body>
</html>
